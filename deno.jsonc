{
  "nodeModulesDir": "auto",
  "workspace": ["tests"],
  "tasks": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "deno check --unstable-tsgo",
    "test": "deno test -A src/ tests/"
  },
  "compilerOptions": {
    "types": ["node"]
  },
  "imports": {
    "oxlint": "npm:oxlint@1.63.0"
  },
  "lint": false,
  "fmt": {
    "proseWrap": "preserve"
  }
}
