{
  "name": "unplugin-license",
  "version": "0.1.0",
  "description": "Collect OSS licenses from bundled files and output third party licenses",
  "type": "module",
  "license": "MIT-0",
  "repository": "ryuapp/unplugin-license",
  "keywords": [
    "unplugin",
    "vite-plugin",
    "rollup-plugin",
    "rolldown-plugin",
    "esbuild-plugin"
  ],
  "exports": {
    "./bun": "./dist/bun.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./vite": "./dist/vite.mjs"
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": "^8.0.0"
    },
    "rollup": {
      "type": "compatible",
      "versions": "^4.0.0"
    },
    "rolldown": {
      "type": "compatible",
      "versions": "^1.0.0"
    }
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260517.1",
    "tsdown": "0.22.0"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ]
}
